<Window x:Class="СуторминУчетЗаявок.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:СуторминУчетЗаявок"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Image Source="237378.png" HorizontalAlignment="Left" Margin="31,2,0,3" Width="70"></Image>
        <TextBlock Text="Учёт заявок в техподдержку" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White" FontFamily="Cooper Black" Height="47" Width="442" Margin="0,18,0,0"></TextBlock>
        <Grid Background="#1c3e50" Panel.ZIndex="-2"></Grid>
        <Grid Grid.Row="2" Background="#1c3e50"></Grid>
        <Frame NavigationUIVisibility="Hidden" ContentRendered="MainFrame_contentrendered"  Grid.Row="1" Name="MainFrame" Foreground="Black"></Frame>
        <Button Content="Назад" Name="BtnBack" HorizontalAlignment="Left" Height="46" Margin="703,0,0,0" VerticalAlignment="Center" Width="65" Background="#90dfaa" Click="BtnBack_Click"/>
    </Grid>
</Window>
